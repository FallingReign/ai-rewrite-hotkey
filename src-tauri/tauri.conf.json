{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rewrite Hotkey",
  "version": "0.0.0",
  "identifier": "com.fallingreign.rewritehotkey",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rewrite Hotkey",
        "width": 320,
        "height": 220,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
